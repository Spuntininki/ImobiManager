# ImobiManager frontend environment variables.
# Copy this file to .env.local and fill in values as needed.
#
# In dev, `npm run dev` uses the Vite proxy defined in vite.config.js
# to forward /api → http://localhost:8000. No env var is needed.
#
# In production, the frontend talks to the backend directly (or via
# same-origin /api path served by a reverse proxy). If a different API
# origin is needed, override VITE_API_BASE_URL and update src/lib/api.js.
# VITE_API_BASE_URL=