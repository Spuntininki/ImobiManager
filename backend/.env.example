# ImobiManager backend — template for local development environment.
# Copy this file to backend/.env and adjust values.
# The root .env in the project root is used by Docker Compose with different values.

# PostgreSQL connection string for the dev database.
DATABASE_URL=postgresql+asyncpg://imobi:imobi@localhost:5433/imobimanager

# PostgreSQL connection string for the test database.
TEST_DATABASE_URL=postgresql+asyncpg://imobi:imobi@localhost:5433/imobimanager_test

# Secret key used by JWT auth (Phase 3+). Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me

# CORS allowlist — comma-separated origins allowed to call the API from a
# browser. Default permits the Vite dev server. In production, set this to
# the real frontend origin(s), e.g. https://imobimanager.com,https://www.imobimanager.com
CORS_ORIGINS=http://localhost:5173