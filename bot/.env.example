# =============================================================================
# ImobiManager Bot - environment variables
# =============================================================================

# Telegram bot token issued by @BotFather.
TELEGRAM_BOT_TOKEN=change-me

# Backend base URL (FastAPI). The bot pod reaches the backend over HTTP only;
# it never connects to the database directly.
BOT_BACKEND_BASE_URL=http://backend:8000

# Shared secret with the backend (must match BOT_MCP_API_KEY on the backend).
BOT_MCP_API_KEY=change-me-bot-key

# Cache TTL (seconds) for token validation results in the bot pod.
BOT_VALIDATE_CACHE_TTL=60

# Message log publisher flush cadence and batch size.
BOT_LOG_FLUSH_INTERVAL=30
BOT_LOG_FLUSH_BATCH_SIZE=100

# OpenRouter (OpenAI-compatible) configuration.
# Default model is free (Google Gemma 4 31B weights, supports tool calling).
# Swap to a paid model (e.g. openai/gpt-4o-mini) for tighter tool-call adherence
# once you are ready; nothing else in the codebase needs to change.
OPENROUTER_API_KEY=change-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Rate limits (hard reject).
BOT_RATE_LIMIT_USER_PER_MIN=10
BOT_RATE_LIMIT_USER_PER_DAY=200
BOT_RATE_LIMIT_RENTER_PER_MIN=5
BOT_RATE_LIMIT_RENTER_PER_DAY=50
BOT_RATE_LIMIT_CHAT_PER_MIN=15

# Telegram long polling configuration.
TELEGRAM_POLLING_TIMEOUT=30
TELEGRAM_POLLING_ERROR_BACKOFF=5