# =============================================================================
# ImobiManager - Docker Compose environment variables
# =============================================================================

# Backend
DATABASE_URL=postgresql+asyncpg://imobi:imobi@postgres:5432/imobimanager
TEST_DATABASE_URL=postgresql+asyncpg://imobi:imobi@postgres:5432/imobimanager_test
SECRET_KEY=change-me
CORS_ORIGINS=["http://localhost:5174"]

# Chat bot integration (shared secret between backend and the bot pod).
# Required for /api/v1/bot/auth/validate, /api/v1/bot/message-logs and /mcp.
BOT_MCP_API_KEY=change-me-bot-key
BOT_TOKEN_LENGTH=12

# Bot service (Telegram polling + LLM via OpenRouter).
TELEGRAM_BOT_TOKEN=change-me
OPENROUTER_API_KEY=change-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Frontend
VITE_API_PROXY_TARGET=http://backend:8000